@model Platform.Application.Common.Models.PagedResult<Platform.Application.DTOs.ProjectDto>
@{
    ViewData["Title"] = "Proyectos";
    var currentStatus = ViewBag.StatusFilter as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Proyectos</h1>
        <a asp-action="Create" class="btn btn-primary">+ Nuevo Proyecto</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form method="get" class="mb-3">
        <select name="status" class="form-select w-auto d-inline-block" onchange="this.form.submit()">
            <option value="">-- Todos los estados --</option>
            <option value="Draft" selected="@(currentStatus == "Draft")">Borrador</option>
            <option value="Active" selected="@(currentStatus == "Active")">Activo</option>
            <option value="Completed" selected="@(currentStatus == "Completed")">Completado</option>
        </select>
    </form>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th>Tareas</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model.Items)
            {
                <tr>
                    <td><strong>@project.Name</strong></td>
                    <td>@project.Description</td>
                    <td>
                        <span class="badge @(project.Status.ToString() == "Active" ? "bg-success" : project.Status.ToString() == "Completed" ? "bg-secondary" : "bg-warning text-dark")">
                            @project.Status
                        </span>
                    </td>
                    <td>@project.CompletedTaskCount / @project.TaskCount</td>
                    <td>
                        <a asp-action="Tasks" asp-route-id="@project.Id" class="btn btn-sm btn-outline-primary">Tareas</a>
                        <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                        @if (project.Status.ToString() == "Draft")
                        {
                            <form asp-action="Activate" asp-route-id="@project.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success">Activar</button>
                            </form>
                        }
                        @if (project.Status.ToString() == "Active")
                        {
                            <form asp-action="Complete" asp-route-id="@project.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-info">Completar</button>
                            </form>
                        }
                        <form asp-action="Delete" asp-route-id="@project.Id" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar proyecto?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-status="@currentStatus">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>
